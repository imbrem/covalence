{
  "name": "covalence",
  "private": true,
  "workspaces": [
    "extensions/*",
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "covalence-client": "workspace:*"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "fmt": "cargo fmt --all",
    "fmt:check": "cargo fmt --all --check",
    "deps": "bun scripts/dep-graph.mjs && bun scripts/purge-ratchet.mjs && bun scripts/tcb-audit.mjs --json",
    "deps:check": "bun scripts/dep-graph.mjs --check && bun scripts/purge-ratchet.mjs --check && bun scripts/tcb-audit.mjs --check",
    "build": "bun scripts/build.mjs all",
    "build:native": "bun scripts/build.mjs native",
    "build:wasm": "bun scripts/build.mjs vscode",
    "build:web": "bun scripts/build.mjs web",
    "build:web-kernel": "bun scripts/build.mjs web-kernel",
    "build:serve": "bun scripts/build.mjs native",
    "build:graph": "bun scripts/build.mjs --list",
    "dev:web": "bun run --filter covalence-web dev",
    "serve": "bun scripts/build.mjs native && bun scripts/dev-serve.mjs",
    "serve:release": "bun scripts/build.mjs native-release && bun scripts/dev-serve.mjs --release",
    "dev:serve": "echo 'Run cov serve --api in another terminal, then:' && bun run dev:web",
    "release": "bun scripts/build.mjs all-release",
    "release:native": "bun scripts/build.mjs native-release",
    "release:wasm": "bun scripts/build.mjs vscode",
    "dev": "echo 'Use: bun run code:browser or bun run code:desktop' && exit 1",
    "code:browser": "bun run build:wasm && bun run --filter covalence-vscode code:browser",
    "code:desktop": "bun run build && bun run --filter covalence-vscode code:desktop",
    "check": "cargo check",
    "bench:setmm": "bun scripts/bench-setmm.mjs",
    "profile:init": "bun scripts/profile-init.mjs",
    "profile:import": "bun scripts/profile-import.mjs",
    "profile:theorem": "bun scripts/profile-theorem.mjs",
    "profile:flame": "bun scripts/flamegraph-import.mjs",
    "opentheory": "bun scripts/opentheory.mjs",
    "opentheory:offline": "bun scripts/opentheory.mjs --offline",
    "build:python": "cd crates/ffi/python && source activate.sh && maturin develop",
    "test:python": "cd crates/ffi/python && source activate.sh && pytest tests/ -v",
    "test:ui": "bun run --filter covalence-ui test",
    "test:web": "bun run --filter covalence-web test",
    "test:wasm-js": "bun run --filter covalence-wasm-js test",
    "build:wasm-build-guest": "cargo build --target wasm32-unknown-unknown --release -p covalence-wasm-build-guest && cp target/wasm32-unknown-unknown/release/covalence_wasm_build_guest.wasm packages/covalence-wasm-js/src/__fixtures__/build_guest.wasm",
    "tcb": "bun scripts/tcb-audit.mjs"
  }
}
