{
  "name": "covalence-vscode",
  "displayName": "Covalence",
  "description": "Language support for Covalence (SMT-LIB, Alethe, WAT)",
  "version": "0.1.0",
  "publisher": "covalence",
  "private": true,
  "engines": {
    "vscode": "^1.88.0"
  },
  "extensionDependencies": [
    "ms-vscode.wasm-wasi-core"
  ],
  "categories": ["Programming Languages"],
  "main": "./dist/desktop/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "smt",
        "aliases": ["SMT-LIB", "SMT"],
        "extensions": [".smt", ".smt2"],
        "configuration": "./smt-language-configuration.json"
      },
      {
        "id": "alethe",
        "aliases": ["Alethe"],
        "extensions": [".alethe"],
        "configuration": "./smt-language-configuration.json"
      },
      {
        "id": "cov",
        "aliases": ["Covalence"],
        "extensions": [".cov"],
        "configuration": "./smt-language-configuration.json"
      },
      {
        "id": "wat",
        "aliases": ["WAT", "WebAssembly Text"],
        "extensions": [".wat"],
        "configuration": "./wat-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "smt",
        "scopeName": "source.smt",
        "path": "./syntaxes/smt.tmLanguage.json"
      },
      {
        "language": "alethe",
        "scopeName": "source.smt",
        "path": "./syntaxes/smt.tmLanguage.json"
      },
      {
        "language": "cov",
        "scopeName": "source.smt",
        "path": "./syntaxes/smt.tmLanguage.json"
      },
      {
        "language": "wat",
        "scopeName": "source.wat",
        "path": "./syntaxes/wat.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Covalence",
      "properties": {
        "covalence.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the native `cov` binary. When set, the extension uses the native binary instead of the built-in WASM server. Supports absolute paths and `${workspaceFolder}`.",
          "scope": "machine-overridable"
        }
      }
    },
    "commands": [
      {
        "command": "covalence.restartLsp",
        "title": "Covalence: Restart LSP"
      }
    ]
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "code:browser": "npx @vscode/test-web --coi --browser none --extensionId ms-vscode.wasm-wasi-core --extensionDevelopmentPath=.",
    "code:desktop": "code --extensionDevelopmentPath=$PWD"
  },
  "dependencies": {
    "@vscode/wasm-wasi": "^1.0.1",
    "@vscode/wasm-wasi-lsp": "^0.1.0-pre.8",
    "vscode-languageclient": "10.0.0-next.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/vscode": "^1.88.0",
    "@vscode/test-web": "^0.0.62",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
