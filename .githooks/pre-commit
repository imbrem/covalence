#!/bin/sh
# Covalence pre-commit hook: keep Rust formatting clean so the CI `fmt` job
# stays green. Wired up by `bun install` (the package.json `prepare` script sets
# `git config core.hooksPath .githooks`).
#
# Behaviour: format the whole workspace, then re-stage anything that was already
# staged and got reformatted. Only touches tracked, staged Rust files' crates —
# `cargo fmt --all` is fast enough to run wholesale.

# Skip if there are no staged Rust files.
if ! git diff --cached --name-only --diff-filter=ACM | grep -q '\.rs$'; then
    exit 0
fi

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-commit: cargo not found, skipping rustfmt" >&2
    exit 0
fi

echo "pre-commit: cargo fmt --all"
cargo fmt --all

# Re-stage any staged Rust files that fmt modified.
git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' | while read -r f; do
    [ -f "$f" ] && git add -- "$f"
done

# Regenerate the dependency graph + TCB closure (docs/deps/) when any manifest
# changes, so the tracked graph and CI `deps:check` stay in sync. Best-effort:
# never block a commit if the toolchain or network is unavailable.
if git diff --cached --name-only --diff-filter=ACM | grep -qE '(^|/)Cargo\.(toml|lock)$'; then
    if command -v bun >/dev/null 2>&1 && command -v cargo >/dev/null 2>&1; then
        echo "pre-commit: regenerating dependency graph (bun run deps)"
        if bun scripts/dep-graph.mjs; then
            git add docs/deps
        else
            echo "pre-commit: dep-graph generation failed; run 'bun run deps' manually" >&2
        fi
    fi
fi

# Purge ratchet (toHOL purge): regenerate docs/deps/purge-ratchet.json when any
# Rust or .cov file changes. Unlike the dep graph, an INCREASE in deprecated
# call-site counts is a policy violation and BLOCKS the commit (the script
# refuses to regenerate); a decrease just refreshes the golden. Tool absence
# never blocks.
if git diff --cached --name-only --diff-filter=ACMD | grep -qE '\.(rs|cov)$'; then
    if command -v bun >/dev/null 2>&1 && command -v rg >/dev/null 2>&1 \
        && command -v cargo >/dev/null 2>&1; then
        echo "pre-commit: purge ratchet (bun scripts/purge-ratchet.mjs)"
        if bun scripts/purge-ratchet.mjs; then
            git add docs/deps/purge-ratchet.json
        else
            echo "pre-commit: purge ratchet failed — deprecated call-site counts may only decrease" >&2
            exit 1
        fi
    fi
fi

exit 0
