package covalence:hash@0.1.0;

/// SHA-512 (FIPS PUB 180-4 §6.4) — resource-based world.
///
/// One module instance can host many concurrent hashers via the `hasher`
/// resource. For the auditability-first / "one wasm instance per hasher"
/// alternative, see `sha512-stateful.wit`.
///
/// Used as the message-hashing dependency of Ed25519-verify (RFC 8032
/// §5.1.7). Exports live in an `api` interface block so the resource
/// methods are host-callable.
interface api {
  resource hasher {
    constructor();
    update: func(data: list<u8>);
    finalize: func() -> list<u8>;
  }

  /// One-shot hash. Derived from `hasher` by `compose_one_shot`.
  hash: func(data: list<u8>) -> list<u8>;

  /// Apply the SHA-512 block compression function once. `state` is the
  /// 64-byte running state (8 BE u64s), `block` is a single 128-byte
  /// input block, return is the new 64-byte state.
  compress: func(state: list<u8>, block: list<u8>) -> list<u8>;
}

world sha512 {
  export api;
}
