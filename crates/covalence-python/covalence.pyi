"""Type stubs for the covalence native module (PyO3)."""

from typing import Optional, Union

class O256:
    """256-bit hash value. Also acts as a BLAKE3 keyed-hash key."""

    @staticmethod
    def from_hex(hex: str) -> "O256": ...
    @staticmethod
    def from_bytes(data: bytes) -> "O256": ...
    @staticmethod
    def blob(data: bytes) -> "O256": ...
    @property
    def hex(self) -> str: ...
    def hash(self, data: bytes) -> "O256": ...
    def hash_file(self, path: str) -> "O256": ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...
    def __bytes__(self) -> bytes: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class GitObject:
    """Git object hash (SHA-1 or SHA-256)."""

    @property
    def hex(self) -> str: ...
    @property
    def kind(self) -> str: ...
    def to_o256(self) -> O256: ...
    def __str__(self) -> str: ...
    def __repr__(self) -> str: ...
    def __bytes__(self) -> bytes: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class Hasher:
    """Hashing strategy that produces O256 values."""

    def hash(self, data: bytes) -> O256: ...
    def hash_file(self, path: str) -> O256: ...

class GitHasher:
    """Git hashing strategy that produces GitObject values."""

    def hash_blob(self, data: bytes) -> GitObject: ...
    def hash_blob_file(self, path: str) -> GitObject: ...
    def hash_tree(self, data: bytes) -> GitObject: ...

class Backend:
    """Covalence backend: content store + WASM engine on a background thread."""

    def store_blob(self, data: bytes) -> O256: ...
    def store_str(self, text: str) -> O256: ...
    def get_blob(self, hash: Union[O256, str]) -> Optional[bytes]: ...
    def has_blob(self, hash: Union[O256, str]) -> bool: ...
    def blob_count(self) -> Optional[int]: ...
    def compile_wat(self, wat: str) -> O256: ...
    def decide(self, hash: Union[O256, str]) -> dict[str, object]: ...
    def info(self) -> dict[str, str]: ...

class Session:
    """REPL session for evaluating S-expression commands."""

    def eval(self, input: str) -> str: ...

class Server:
    """Background embedded HTTP server."""

    @property
    def port(self) -> int: ...
    @property
    def url(self) -> str: ...
    def stop(self) -> None: ...
    def __enter__(self) -> "Server": ...
    def __exit__(self, exc_type: object, exc_val: object, exc_tb: object) -> bool: ...

def local() -> Backend: ...
def local_persistent(path: str) -> Backend: ...
def session_local() -> Session: ...
def serve(port: int = 0, store: Optional[str] = None) -> Server: ...
def blake3() -> Hasher: ...
def blake3_keyed(key: O256) -> Hasher: ...
def blake3_kdf(ctx: str) -> Hasher: ...
def sha256() -> Hasher: ...
def hasher(name: str) -> Hasher: ...
def git_sha1() -> GitHasher: ...
def git_sha256() -> GitHasher: ...

# Module-level convenience functions (lazy default backend)
def store(data: bytes) -> O256: ...
def store_str(text: str) -> O256: ...
def get(hash: Union[O256, str]) -> Optional[bytes]: ...
def has(hash: Union[O256, str]) -> bool: ...
def compile_wat(wat: str) -> O256: ...
def decide(hash: Union[O256, str]) -> dict[str, object]: ...
