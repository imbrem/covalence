{
  "name": "tree-sitter-sexp",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for SMT-LIB / Alethe S-expressions",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "parser", "smt-lib", "s-expression"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.sexp",
      "file-types": ["smt", "smt2", "alethe"],
      "injection-regex": "sexp"
    }
  ]
}
