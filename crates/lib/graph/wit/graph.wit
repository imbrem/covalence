package cov:graph@0.1.0;

/// Ordered, typed, payload-polymorphic graph — *pure topology*.
///
/// Labels and per-node "ordered/pure" classification are NOT here:
/// they live in independently content-addressed overlay blobs and a
/// `string-diagram` composite that references them. See the
/// `string-diagram` interface in this package.
///
/// **Order matters.** Nodes form an ordered sequence — first added,
/// first initialized. The intended interpretation is a symmetric
/// *premonoidal* category: parallel composition (side-by-side nodes)
/// is still strictly ordered because each node may perform effects.
/// Two graphs with the same nodes/edges but a different insertion
/// order are NOT equal; `equal` and the snapshot APIs preserve order.
///
/// Edges are also ordered by insertion. This matches the "wire-up
/// log" reading: a graph is a sequence of (add-node | wire) events,
/// and equal graphs are equal sequences.
interface api {
    /// Opaque type identifier — graph only checks equality.
    /// Conventional uses: hash of a WIT interface name (linker), object
    /// id in a SMC presentation (string diagram), monad-effect id, …
    type type-id = u64;

    /// Stable, 0-based index into the node insertion order.
    type node-id = u32;

    /// Stable, 0-based index into a node's port list (in declaration
    /// order). `(node-id, port-id)` uniquely identifies a port.
    type port-id = u32;

    enum port-kind { input, output }

    record port {
        name: string,
        type-id: type-id,
        kind: port-kind,
    }

    /// Opaque per-node bytes; the graph never inspects them.
    type payload = list<u8>;

    record node {
        ports: list<port>,
        payload: payload,
    }

    /// Output port -> input port. Only output→input wires are valid.
    record edge {
        from-node: node-id, from-port: port-id,
        to-node: node-id,   to-port: port-id,
    }

    /// Frozen view of a graph. Insertion order preserved in both
    /// `nodes` and `edges`.
    record snapshot {
        nodes: list<node>,
        edges: list<edge>,
    }

    variant wire-error {
        unknown-node(node-id),
        unknown-port(tuple<node-id, port-id>),
        /// `from` must be an output port, `to` must be an input port.
        kind-mismatch,
        /// `from-port.type-id` differs from `to-port.type-id`.
        type-mismatch(tuple<type-id, type-id>),
        /// Input ports may be wired at most once (linear-in).
        /// Output ports may fan out freely (re-wire is allowed).
        already-wired(tuple<node-id, port-id>),
    }

    variant build-error {
        /// An input port had no incoming edge.
        unwired-input(tuple<node-id, port-id>),
    }

    /// Mutable graph being assembled.
    resource builder {
        constructor();

        /// Append a node. Returns its id. The new id is always
        /// `prior-node-count` — i.e. insertion order = id order.
        add-node: func(ports: list<port>, payload: payload) -> node-id;

        /// Append an edge. Type compatibility and port kinds are
        /// checked here, not at `finish`.
        wire: func(e: edge) -> result<_, wire-error>;

        /// Read-only snapshot without consuming. Useful for incremental
        /// inspection during construction.
        peek: func() -> snapshot;

        /// Finalize and return the graph as a graph resource.
        /// Checks that every input port has exactly one incoming edge.
        finish: func() -> result<graph, build-error>;
    }

    /// Immutable, fully-built graph. All inspect / compare ops live
    /// here so a guest can hand a graph to a separate consumer without
    /// re-exposing the builder.
    resource graph {
        /// Reconstruct from a snapshot (e.g. for IPC or cache hits).
        /// Same checks as `builder.finish`.
        from-snapshot: static func(s: snapshot) -> result<graph, build-error>;

        // ---- Inspect ----

        snapshot: func() -> snapshot;
        node-count: func() -> u32;
        edge-count: func() -> u32;

        /// Node by id, in insertion order.
        get-node: func(n: node-id) -> option<node>;

        /// Edges in insertion order whose `from-node == n`. If
        /// `port` is `some`, restricts to that output port.
        edges-from: func(n: node-id, port: option<port-id>) -> list<edge>;

        /// Edges in insertion order whose `to-node == n`. If
        /// `port` is `some`, restricts to that input port.
        edges-into: func(n: node-id, port: option<port-id>) -> list<edge>;

        // ---- Compare ----
        //
        // Canonical byte encoding and content hashing are HOST-side
        // operations and deliberately NOT in this WIT — the encoding
        // is internal to the host crate.

        /// Strict structural equality, preserving insertion order of
        /// both nodes and edges. Two graphs that differ only in the
        /// order they were assembled in are NOT equal.
        equal: func(other: borrow<graph>) -> bool;
    }
}

/// String-diagram composite: a graph hash plus references to optional
/// label and node-kind overlays.
///
/// Slots are 32-byte fields. The all-zero value means "absent" — the
/// renderer falls back to defaults. A reserved `0xFF`-prefixed pattern
/// encodes "uniform" sentinels (all-pure, all-ordered) so degenerate
/// overlays don't have to allocate a blob.
interface string-diagram {
    use api.{node-id};

    /// 32-byte BLAKE3 hash.
    type hash = list<u8>;

    /// One slot of a string-diagram: a hash, the all-zero "absent"
    /// pattern, or the `0xFF`-prefixed uniform sentinel. Encoded
    /// directly as a fixed 32-byte payload so canonical bytes are
    /// constant-shape.
    type slot = list<u8>;

    /// Built-in per-node classification.
    /// `pure`    : commutes freely with siblings.
    /// `ordered` : effectful; consecutive ordered nodes carry a
    ///   dashed-red "state thread" in the diagrammatic view.
    enum node-kind { pure, ordered }

    /// Canonical references only. Just enough to compute a stable
    /// content hash and look up the pieces.
    record diagram-refs {
        /// Ordered-domain hash of the underlying graph.
        graph: hash,
        /// Reference to the label-list overlay (or absent / uniform).
        labels: slot,
        /// Reference to the kind-flags overlay (or absent / uniform).
        kinds: slot,
    }

    /// Inline label-list: one entry per node. `none` means "no label
    /// for this slot — renderers fall back to `#i`."
    record label-list {
        labels: list<option<string>>,
    }

    /// Inline kind-flags: one entry per node.
    record kind-flags {
        kinds: list<node-kind>,
    }

    /// Encode a label-list to its canonical bytes for content hashing.
    label-list-to-bytes: func(ll: label-list) -> list<u8>;
    /// Encode kind-flags to its canonical bytes for content hashing.
    kind-flags-to-bytes: func(kf: kind-flags) -> list<u8>;
    /// Encode a diagram-refs composite to its canonical bytes.
    diagram-to-bytes: func(d: diagram-refs) -> list<u8>;

    /// Render the composite to standalone SVG markup. The renderer
    /// needs the inline overlays alongside the graph bytes; the WIT
    /// caller is responsible for resolving overlay hashes against
    /// whatever store it knows about.
    record renderable {
        graph-bytes: list<u8>,
        labels: option<label-list>,
        kinds: option<kind-flags>,
    }

    render-svg: func(r: renderable) -> result<string, string>;
}

/// World exporting just the graph topology resource. WASM components
/// that build / inspect graphs without caring about the diagrammatic
/// presentation use this.
world graph-tool { export api; }

/// World exporting both graph and string-diagram. WASM components
/// that render or transform diagrams use this.
world diagram-tool {
    export api;
    export string-diagram;
}
