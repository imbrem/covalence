         bool.cases cond.cong_arm
         bool.eqt bool.eqf or.true_l or.true_r or.false_l
         cond.cong_guard cond.eq_then cond.eq_else
         nat.le_add_l nat.lt_add_l nat.not_lt_of_ge
         div.zero div.step_lt div.step_ge div.bounds)
